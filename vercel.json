{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/aarrr-dashboard run build",
  "outputDirectory": "artifacts/aarrr-dashboard/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/:path*", "destination": "/index.html" }
  ]
}
